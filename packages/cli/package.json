{
  "name": "memax-cli",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.3",
  "description": "CLI for Memax — universal context & memory hub for AI agents",
  "homepage": "https://memax.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MemaxLabs/memax.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "email": "support@memax.app"
  },
  "type": "module",
  "bin": {
    "memax": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "memax-sdk": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "memax",
    "ai",
    "memory",
    "context",
    "cli",
    "claude-code",
    "agent"
  ],
  "files": [
    "dist",
    "assets",
    "NOTICE"
  ],
  "license": "Apache-2.0"
}
